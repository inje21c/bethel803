# Frontend runtime env for staging-oriented local development
# Copy selected values into .env.local only after the staging Supabase project exists.

VITE_SUPABASE_URL=https://your-staging-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-supabase-anon-key
VITE_APP_URL=http://localhost:8080
VITE_VAPID_PUBLIC_KEY=your-staging-base64-url-vapid-public-key
VITE_APP_VERSION=staging-preview

# Notes
# - Do not commit real secrets.
# - Prefer connecting EC2 dev and Vercel Preview to staging, not production.
# - VITE_APP_URL should later align with the actual local or preview URL used in Auth redirect settings.
