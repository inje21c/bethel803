# Frontend runtime env
# Copy to .env.local for local development, or configure equivalent values in your hosting platform.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=http://localhost:8080
VITE_VAPID_PUBLIC_KEY=your-base64-url-vapid-public-key
VITE_APP_VERSION=local-dev

# Notes
# - VITE_APP_URL must match the URL used in Supabase Auth redirect settings.
# - VITE_VAPID_PUBLIC_KEY is the public web-push key only. Never expose the private key.
# - Do not put service_role or OpenAI API keys in frontend env files.
